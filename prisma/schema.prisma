// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_DIRECT_URL")
}

enum UserRole {
  USER
  ADMIN
  BRAND_ADMIN
  PRINTER
}

enum OrderStatus {
  DRAFT
  SUBMITTED
  IN_PRODUCTION
  COMPLETED
  CANCELLED
}

enum TemplateAssetType {
  PDF
  PREVIEW_FRONT
  PREVIEW_BACK
  CONFIG
  OTHER
}

enum JdfExportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum FontStyle {
  NORMAL
  ITALIC
}

enum FontFormat {
  TTF
  OTF
  WOFF
  WOFF2
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  image          String?
  emailVerified  DateTime?
  role           UserRole  @default(USER)
  jobTitle       String?
  department     String?
  mobilePhone    String?
  businessPhone  String?
  url            String?
  locale         String    @default("en")
  hashedPassword String?
  brandId        String?
  brand          Brand?    @relation(fields: [brandId], references: [id])
  accounts       Account[]
  sessions       Session[]
  passwordResetTokens PasswordResetToken[]
  orders         Order[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @map("refreshToken")
  access_token      String? @map("accessToken")
  expires_at        Int?    @map("expiresAt")
  token_type        String? @map("tokenType")
  ext_expires_in    Int?    @map("extExpiresIn")
  scope             String?
  id_token          String? @map("idToken")
  session_state     String? @map("sessionState")
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationTokens")
}

model Brand {
  id        String          @id @default(cuid())
  name      String
  slug      String          @unique
  contactName  String?
  contactEmail String?
  contactPhone String?
  users     User[]
  orders    Order[]
  templates BrandTemplate[]
  defaultTemplateId String?
  defaultTemplate   Template?      @relation("BrandDefaultTemplate", fields: [defaultTemplateId], references: [id])
  addresses BrandAddress[]
  domains   BrandDomain[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model BrandAddress {
  id           String   @id @default(cuid())
  brandId      String
  label        String?
  company      String?
  street       String?
  addressExtra String?
  postalCode   String?
  city         String?
  countryCode  String?
  cardAddressText String?
  url          String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([brandId])
}

model BrandDomain {
  id        String   @id @default(cuid())
  brandId   String
  domain    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, domain])
  @@index([domain])
}

model Template {
  id               String          @id @default(cuid())
  key              String          @unique
  label            String
  description      String?
  paperStockId     String?
  pdfPath          String
  previewFrontPath String?
  previewBackPath  String?
  config           Json
  layoutVersion    Int?
  printDpi         Int?
  pcmCode          String?
  orders           Order[]
  assignments      BrandTemplate[]
  brandDefaults    Brand[]         @relation("BrandDefaultTemplate")
  assets           TemplateAsset[]
  fonts            TemplateFont[]
  paperStock       PaperStock?     @relation(fields: [paperStockId], references: [id])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model PaperStock {
  id          String     @id @default(cuid())
  name        String
  description String?
  finish      String?
  color       String?
  weightGsm   Int?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  templates   Template[]
}

model BrandTemplate {
  id             String   @id @default(cuid())
  brandId        String
  templateId     String
  assignedAt     DateTime @default(now())
  configOverride Json?
  orderIndex     Int      @default(0)

  brand    Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([brandId, templateId])
  @@index([brandId, orderIndex])
}

model Order {
  id             String      @id @default(cuid())
  referenceCode  String      @unique
  referenceYear  Int?
  referenceSequence Int?
  userId         String
  brandId        String?
  templateId     String?
  status         OrderStatus @default(SUBMITTED)
  quantity       Int
  deliveryTime   String
  deliveryDueAt  DateTime?
  requesterName  String
  requesterRole  String?
  requesterEmail String
  phone          String?
  mobile         String?
  company        String?
  url            String?
  linkedin       String?
  pdfUrl         String?
  blobId         String?
  pdfFileName    String?
  jdfUrl         String?
  jdfBlobId      String?
  jdfFileName    String?
  meta           Json?
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand          Brand?      @relation(fields: [brandId], references: [id])
  template       Template?   @relation(fields: [templateId], references: [id])
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  jdfJob         JdfExportJob?

  @@index([brandId])
  @@index([templateId])
}

model JdfExportJob {
  id           String           @id @default(cuid())
  orderId      String           @unique
  order        Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  pdfUrl       String
  jdfXml       String
  status       JdfExportStatus  @default(PENDING)
  attemptCount Int              @default(0)
  lastError    String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model OrderReferenceCounter {
  year      Int    @id
  lastValue Int    @default(0)
  updatedAt DateTime @updatedAt
}

model TemplateAsset {
  id         String            @id @default(cuid())
  templateId String
  type       TemplateAssetType
  storageKey String
  mimeType   String
  fileName   String?
  checksum   String?
  version    Int               @default(1)
  sizeBytes  Int?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([templateId, type])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model FontFamily {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  defaultWeight Int?          @default(400)
  defaultStyle  FontStyle?    @default(NORMAL)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  variants      FontVariant[]

  @@unique([name])
}

model FontVariant {
  id             String     @id @default(cuid())
  fontFamilyId   String
  weight         Int        @default(400)
  style          FontStyle  @default(NORMAL)
  format         FontFormat
  storageKey     String
  fileName       String?
  postscriptName String?
  checksum       String?
  sizeBytes      Int?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  fontFamily FontFamily     @relation(fields: [fontFamilyId], references: [id], onDelete: Cascade)
  templates  TemplateFont[]

  @@unique([fontFamilyId, weight, style, format])
  @@index([fontFamilyId])
}

model TemplateFont {
  id            String   @id @default(cuid())
  templateId    String
  fontVariantId String
  usage         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  template    Template    @relation(fields: [templateId], references: [id], onDelete: Cascade)
  fontVariant FontVariant @relation(fields: [fontVariantId], references: [id], onDelete: Cascade)

  @@unique([templateId, fontVariantId])
  @@index([fontVariantId])
}
