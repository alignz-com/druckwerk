// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  BRAND_ADMIN
  PRINTER
}

enum OrderStatus {
  DRAFT
  SUBMITTED
  IN_PRODUCTION
  READY_FOR_DELIVERY
  COMPLETED
  CANCELLED
}

enum BrandQrMode {
  VCARD_ONLY
  PUBLIC_PROFILE_ONLY
  BOTH
}

enum ContactStatus {
  DRAFT
  CONFIRMED
  EXPIRED
}

enum TemplateAssetType {
  PDF
  PREVIEW_FRONT
  PREVIEW_BACK
  CONFIG
  OTHER
}

enum JdfExportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum OrderType {
  TEMPLATE
  UPLOAD
}

enum ProductType {
  TEMPLATE
  UPLOAD
}

enum FontStyle {
  NORMAL
  ITALIC
}

enum FontFormat {
  TTF
  OTF
  WOFF
  WOFF2
}

enum FeatureStatus {
  IDEA
  PLANNED
  READY
  IN_PROGRESS
  DONE
  PARKED
}

enum FeaturePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FeatureCategory {
  UI
  UX
  BACKEND
  INFRASTRUCTURE
  BUG
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  image          String?
  emailVerified  DateTime?
  role           UserRole  @default(USER)
  jobTitle       String?
  department     String?
  mobilePhone    String?
  businessPhone  String?
  url            String?
  locale         String    @default("en")
  hashedPassword String?
  brandId        String?
  brand          Brand?    @relation(fields: [brandId], references: [id])
  accounts       Account[]
  sessions       Session[]
  passwordResetTokens PasswordResetToken[]
  canUseTemplates       Boolean?
  canUploadFiles        Boolean?
  isDemo                Boolean   @default(false)
  orders         Order[]
  orderProfiles  UserOrderProfile[]
  deliveriesCreated Delivery[] @relation("UserDeliveries")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([brandId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @map("refreshToken")
  access_token      String? @map("accessToken")
  expires_at        Int?    @map("expiresAt")
  token_type        String? @map("tokenType")
  ext_expires_in    Int?    @map("extExpiresIn")
  scope             String?
  id_token          String? @map("idToken")
  session_state     String? @map("sessionState")
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationTokens")
}

model Brand {
  id        String          @id @default(cuid())
  name      String
  slug      String          @unique
  contactName  String?
  contactEmail String?
  contactPhone String?
  logoUrl   String?
  qrMode    BrandQrMode    @default(VCARD_ONLY)
  defaultQrMode BrandQrMode?
  quantityMin Int?
  quantityMax Int?
  quantityStep Int?
  quantityOptions         Int[]       @default([])
  canUseTemplates         Boolean     @default(true)
  canUploadFiles          Boolean     @default(false)
  azureTenantId           String?     @unique
  users              User[]
  orders             Order[]
  templates          BrandTemplate[]
  productFormatPreferences BrandProductFormatPreference[]
  defaultTemplateId String?
  defaultTemplate   Template?      @relation("BrandDefaultTemplate", fields: [defaultTemplateId], references: [id])
  addresses BrandAddress[]
  domains   BrandDomain[]
  publicDomains BrandPublicDomain[]
  contacts  Contact[]
  orderProfiles UserOrderProfile[]
  deliveries Delivery[] @relation("BrandDeliveries")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model BrandAddress {
  id           String   @id @default(cuid())
  brandId      String
  label        String?
  company      String?
  street       String?
  addressExtra String?
  postalCode   String?
  city         String?
  countryCode  String?
  cardAddressText String?
  url          String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)
  templateAssignments TemplateAddress[]

  @@index([brandId])
}

model BrandDomain {
  id        String   @id @default(cuid())
  brandId   String
  domain    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, domain])
  @@index([domain])
}

model BrandPublicDomain {
  id        String   @id @default(cuid())
  brandId   String
  domain    String   @unique
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([brandId, isPrimary])
}

model Contact {
  id         String   @id @default(cuid())
  publicId   String   @unique
  brandId    String
  status     ContactStatus @default(CONFIRMED)
  expiresAt  DateTime?
  firstName  String
  lastName   String
  title      String?
  department String?
  email      String?
  phone      String?
  mobile     String?
  website    String?
  linkedin   String?
  photoUrl   String?
  addressId  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([brandId])
}

model UserOrderProfile {
  id           String   @id @default(cuid())
  userId       String
  brandId      String
  name         String?
  jobTitle     String?
  seniority    String?
  email        String?
  phone        String?
  mobile       String?
  url          String?
  linkedin     String?
  addressId    String?
  addressLabel String?
  companyName  String?
  street       String?
  postalCode   String?
  city         String?
  countryCode  String?
  addressBlock String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([userId, brandId])
}

model Template {
  id               String          @id @default(cuid())
  key              String          @unique
  label            String
  description      String?
  paperStockId     String?
  productId        String?
  pdfPath          String
  previewFrontPath String?
  previewBackPath  String?
  config           Json
  layoutVersion    Int?
  // Kept for backwards compat — prefer product.printDpi / product.canvasWidthMm etc. when productId is set
  printDpi         Int?
  pageWidthMm      Float?
  pageHeightMm     Float?
  canvasWidthMm    Float?
  canvasHeightMm   Float?
  spotColors       Json?
  pcmCode          String?
  hasQrCode        Boolean         @default(false)
  hasPhotoSlot     Boolean         @default(false)
  orders           Order[]
  assignments      BrandTemplate[]
  brandDefaults    Brand[]         @relation("BrandDefaultTemplate")
  assets           TemplateAsset[]
  fonts            TemplateFont[]
  paperStock       PaperStock?     @relation(fields: [paperStockId], references: [id])
  product          Product?        @relation(fields: [productId], references: [id])
  productFormatId  String?
  productFormat    ProductFormat?  @relation(fields: [productFormatId], references: [id])
  addressAssignments TemplateAddress[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model TemplateAddress {
  id             String   @id @default(cuid())
  templateId     String
  brandAddressId String
  createdAt      DateTime @default(now())

  template     Template     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  brandAddress BrandAddress @relation(fields: [brandAddressId], references: [id], onDelete: Cascade)

  @@unique([templateId, brandAddressId])
  @@index([templateId])
  @@index([brandAddressId])
}

model PaperStock {
  id              String              @id @default(cuid())
  name            String
  description     String?
  finish          String?
  color           String?
  weightGsm       Int?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  templates               Template[]
  productFormatPapers     ProductFormatPaper[]
  brandCoverPreferences   BrandProductFormatPreference[] @relation("BrandCoverPaper")
  brandContentPreferences BrandProductFormatPreference[] @relation("BrandContentPaper")
  orderItemsCover         PdfOrderItem[]                 @relation("OrderItemCoverPaper")
  orderItemsContent       PdfOrderItem[]                 @relation("OrderItemContentPaper")
}


model BrandTemplate {
  id             String   @id @default(cuid())
  brandId        String
  templateId     String
  assignedAt     DateTime @default(now())
  configOverride Json?
  orderIndex     Int      @default(0)

  brand    Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([brandId, templateId])
  @@index([brandId, orderIndex])
}

model Order {
  id             String      @id @default(cuid())
  referenceCode  String      @unique
  referenceYear  Int?
  referenceSequence Int?
  userId         String
  brandId        String?
  templateId     String?
  type           OrderType   @default(TEMPLATE)
  status         OrderStatus @default(SUBMITTED)
  quantity       Int?
  notes          String?
  deliveryTime   String
  deliveryDueAt  DateTime?
  requesterName  String?
  requesterRole  String?
  requesterSeniority String?
  requesterEmail String?
  phone          String?
  mobile         String?
  company        String?
  url            String?
  linkedin       String?
  photoOriginalUrl String?
  photoCroppedUrl String?
  photoMeta      Json?
  thumbnailUrl   String?
  pdfUrl         String?
  blobId         String?
  pdfFileName    String?
  jdfUrl         String?
  jdfBlobId      String?
  jdfFileName    String?
  meta           Json?
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand          Brand?      @relation(fields: [brandId], references: [id])
  template       Template?   @relation(fields: [templateId], references: [id])
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  jdfJobs        JdfExportJob[]
  deliveryItems  DeliveryItem[]
  pdfOrderItems  PdfOrderItem[]

  @@index([brandId])
  @@index([templateId])
  @@index([type])
}

model JdfExportJob {
  id              String          @id @default(cuid())
  orderId         String
  pdfOrderItemId  String?         @unique
  order           Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  pdfOrderItem    PdfOrderItem?   @relation(fields: [pdfOrderItemId], references: [id], onDelete: Cascade)
  pdfUrl          String?
  jdfUrl          String?
  jdfFileName     String?
  jdfXml          String
  status          JdfExportStatus @default(PENDING)
  attemptCount    Int             @default(0)
  lastError       String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([orderId])
}

model OrderReferenceCounter {
  year      Int    @id
  lastValue Int    @default(0)
  updatedAt DateTime @updatedAt
}

model Delivery {
  id               String          @id @default(cuid())
  number           String          @unique
  note             String?
  deliveryNoteUrl  String?
  brandId          String
  shippingName     String?
  shippingCompany  String?
  shippingStreet   String?
  shippingPostalCode String?
  shippingCity     String?
  shippingCountryCode String?
  shippingAddressExtra String?
  createdByUserId  String
  createdBy        User            @relation("UserDeliveries", fields: [createdByUserId], references: [id])
  brand            Brand           @relation("BrandDeliveries", fields: [brandId], references: [id])
  items            DeliveryItem[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model DeliveryItem {
  id          String    @id @default(cuid())
  deliveryId  String
  orderId     String    @unique
  position    Int       @default(0)
  delivery    Delivery  @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([deliveryId])
}

model DeliveryReferenceCounter {
  year      Int    @id
  lastValue Int    @default(0)
  updatedAt DateTime @updatedAt
}

model TemplateAsset {
  id         String            @id @default(cuid())
  templateId String
  type       TemplateAssetType
  storageKey String
  mimeType   String
  fileName   String?
  checksum   String?
  version    Int               @default(1)
  sizeBytes  Int?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([templateId, type])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model FontFamily {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  defaultWeight Int?          @default(400)
  defaultStyle  FontStyle?    @default(NORMAL)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  variants      FontVariant[]

  @@unique([name])
}

model FontVariant {
  id             String     @id @default(cuid())
  fontFamilyId   String
  weight         Int        @default(400)
  style          FontStyle  @default(NORMAL)
  format         FontFormat
  storageKey     String
  fileName       String?
  postscriptName String?
  checksum       String?
  sizeBytes      Int?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  fontFamily FontFamily     @relation(fields: [fontFamilyId], references: [id], onDelete: Cascade)
  templates  TemplateFont[]

  @@unique([fontFamilyId, weight, style, format])
  @@index([fontFamilyId])
}

model TemplateFont {
  id            String   @id @default(cuid())
  templateId    String
  fontVariantId String
  usage         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  template    Template    @relation(fields: [templateId], references: [id], onDelete: Cascade)
  fontVariant FontVariant @relation(fields: [fontVariantId], references: [id], onDelete: Cascade)

  @@unique([templateId, fontVariantId])
  @@index([fontVariantId])
}

model Product {
  id              String         @id @default(cuid())
  name            String
  description     String?
  type            ProductType
  trimWidthMm     Float?
  trimHeightMm    Float?
  toleranceMm     Float?
  expectedBleedMm Float?
  canvasWidthMm   Float?
  canvasHeightMm  Float?
  printDpi        Int?
  pcmCode         String?
  nameEn          String?
  nameDe          String?
  minPages        Int?
  maxPages        Int?
  templates       Template[]
  productFormats  ProductFormat[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([type])
}

model PdfOrderItem {
  id                   String   @id @default(cuid())
  orderId              String
  filename             String
  sourceZipFilename    String?
  storagePath          String?
  thumbnailStoragePath String?
  quantity             Int      @default(1)
  trimWidthMm          Float?
  trimHeightMm         Float?
  bleedMm              Float?
  colorSpaces          String[] @default([])
  pantoneColors        String[] @default([])
  pages                Int?
  pdfUrl               String?
  pdfFileName          String?
  productFormatId      String?
  coverPaperStockId    String?
  contentPaperStockId  String?
  finishId             String?
  order                Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  jdfJob               JdfExportJob?
  productFormat        ProductFormat? @relation(fields: [productFormatId], references: [id])
  coverPaperStock      PaperStock?   @relation("OrderItemCoverPaper", fields: [coverPaperStockId], references: [id])
  contentPaperStock    PaperStock?   @relation("OrderItemContentPaper", fields: [contentPaperStockId], references: [id])
  finish               Finish?       @relation(fields: [finishId], references: [id])
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([orderId])
  @@index([productFormatId])
}

// ─── Format / ProductFormat ───────────────────────────────────────────────────

model Format {
  id             String          @id @default(cuid())
  name           String
  nameDe         String?
  slug           String          @unique
  trimWidthMm    Float
  trimHeightMm   Float
  defaultBleedMm Float           @default(3.0)
  toleranceMm    Float           @default(1.0)
  productFormats ProductFormat[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model ProductFormat {
  id              String                         @id @default(cuid())
  productId       String
  formatId        String
  pcmCode         String?
  printDpi        Int?
  canvasWidthMm   Float?
  canvasHeightMm  Float?
  productionSteps String[]                       @default([])
  minPages        Int?
  maxPages        Int?
  isActive        Boolean                        @default(true)
  product         Product                        @relation(fields: [productId], references: [id], onDelete: Cascade)
  format          Format                         @relation(fields: [formatId], references: [id], onDelete: Cascade)
  papers          ProductFormatPaper[]
  finishes        ProductFormatFinish[]
  brandPreferences BrandProductFormatPreference[]
  templates       Template[]
  pdfOrderItems   PdfOrderItem[]
  createdAt       DateTime                       @default(now())
  updatedAt       DateTime                       @updatedAt

  @@unique([productId, formatId])
  @@index([productId])
  @@index([formatId])
}

model ProductFormatPaper {
  id              String        @id @default(cuid())
  productFormatId String
  paperStockId    String
  role            String?       // "cover" | "content" | null (null = single-paper product)
  isDefault       Boolean       @default(false)
  productFormat   ProductFormat @relation(fields: [productFormatId], references: [id], onDelete: Cascade)
  paperStock      PaperStock    @relation(fields: [paperStockId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@index([productFormatId])
}

model Finish {
  id               String                         @id @default(cuid())
  name             String
  nameDe           String?
  code             String?
  productFinishes  ProductFormatFinish[]
  brandPreferences BrandProductFormatPreference[]
  orderItems       PdfOrderItem[]
  createdAt        DateTime                       @default(now())
  updatedAt        DateTime                       @updatedAt
}

model ProductFormatFinish {
  id              String        @id @default(cuid())
  productFormatId String
  finishId        String
  isDefault       Boolean       @default(false)
  productFormat   ProductFormat @relation(fields: [productFormatId], references: [id], onDelete: Cascade)
  finish          Finish        @relation(fields: [finishId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@unique([productFormatId, finishId])
  @@index([productFormatId])
}

model BrandProductFormatPreference {
  id                  String        @id @default(cuid())
  brandId             String
  productFormatId     String
  coverPaperStockId   String?
  contentPaperStockId String?
  finishId            String?
  notes               String?
  brand               Brand         @relation(fields: [brandId], references: [id], onDelete: Cascade)
  productFormat       ProductFormat @relation(fields: [productFormatId], references: [id], onDelete: Cascade)
  coverPaperStock     PaperStock?   @relation("BrandCoverPaper", fields: [coverPaperStockId], references: [id])
  contentPaperStock   PaperStock?   @relation("BrandContentPaper", fields: [contentPaperStockId], references: [id])
  finish              Finish?       @relation(fields: [finishId], references: [id])
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@unique([brandId, productFormatId])
  @@index([brandId])
}

// ─── Feature Tracker ──────────────────────────────────────────────────────────

model Feature {
  id          String          @id @default(cuid())
  title       String
  description String?
  imageUrls   String[]          @default([])
  section     String?
  status      FeatureStatus   @default(IDEA)
  priority    FeaturePriority @default(MEDIUM)
  category    FeatureCategory @default(UX)
  sortOrder   Int             @default(0)
  completedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  comments    FeatureComment[]

  @@index([status])
  @@index([priority])
}

model FeatureComment {
  id        String   @id @default(cuid())
  featureId String
  content   String
  author    String
  createdAt DateTime @default(now())

  feature Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@index([featureId])
}
